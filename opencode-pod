#!/usr/bin/env bash
# opencode-pod — Secure, disposable dev containers for OpenCode agents.
# Rootless Podman, Wolfi images, one command.

set -euo pipefail

SCRIPT_VERSION="0.2.0"

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/lib"
DEFAULTS_DIR="${SCRIPT_DIR}/defaults"

if [[ ! -d "$LIB_DIR" ]]; then
  LIB_DIR="$HOME/.local/share/opencode-pod/lib"
  DEFAULTS_DIR="$HOME/.local/share/opencode-pod/defaults"
fi

export OPCODE_POD_LIB_DIR="${LIB_DIR}"

# shellcheck disable=SC1091
source "${LIB_DIR}/toml.sh"
# shellcheck disable=SC1091
source "${LIB_DIR}/distro.sh"
# shellcheck disable=SC1091
source "${LIB_DIR}/podman.sh"
# shellcheck disable=SC1091
source "${LIB_DIR}/security.sh"
# shellcheck disable=SC1091
source "${LIB_DIR}/profiles.sh"

usage() {
  cat << 'EOF'
Usage: opencode-pod <command> [options]

Commands:
  init       Create opencode-pod.toml (offline, instant)
  setup      Pull image, create container, install packages (one-time, ~60s)
  start      Enter container shell (instant)
  stop       Stop container, preserve installed tools
  destroy    Remove container + home volume
  status     Show container state, project path
  doctor     Health check: podman, image, SELinux, disk space
  upgrade    Check base image freshness, install new packages from TOML
  profile    Manage OpenCode profiles (list, info, install, update)

Options:
  --help     Show this message
  --version  Show version
EOF
}

cmd_status() {
  resolve_project || return 1
  printf 'Container: %s\n' "$CONTAINER_NAME"
  printf 'State: %s\n' "$CONTAINER_STATE"
  printf 'Project: %s\n' "$(pwd)"
  if [[ -n "${CONFIG_CONTAINER_IMAGE:-}" ]]; then
    printf 'Image: %s\n' "${CONFIG_CONTAINER_IMAGE}"
  fi
}

cmd_init() {
  local config_file
  config_file="$(pwd)/opencode-pod.toml"
  if [[ -f "$config_file" ]]; then
    printf 'opencode-pod.toml already exists in this directory.\n'
    printf 'Edit it directly or remove it and re-run init.\n'
    return 1
  fi

  local default_config="${DEFAULTS_DIR}/opencode-pod.toml"
  if [[ -f "$default_config" ]]; then
    cp "$default_config" "$config_file"
    printf 'Created opencode-pod.toml with defaults.\n'
    printf 'Edit it to customize packages, mounts, and security options.\n'
  else
    cat > "$config_file" << 'TOML'
[container]
image = "cgr.dev/chainguard/wolfi-base:latest"
packages = ["git", "openssh", "curl"]
user = "dev"

[mounts]
extra = []

[env]

[network]
forward = []
mode = "bridge"

[security]
http = false
harden = true
TOML
    printf 'Created opencode-pod.toml\n'
  fi
}

cmd_start() {
  resolve_project || return 1

  if [[ -n "${AUTO_DETECTED_PROFILE:-}" ]]; then
    printf 'Detected %s project.\n' "$AUTO_DETECTED_PROFILE"
    printf 'Installing: %s\n' "$AUTO_DETECTED_PACKAGES"
    printf 'Press Enter to confirm, or type "init" for interactive config: '
    read -r response
    if [[ "$response" == "init" ]]; then
      cmd_init
      return 0
    fi
    local quoted_pkgs=""
    # shellcheck disable=SC2086
    for pkg in $AUTO_DETECTED_PACKAGES; do
      quoted_pkgs="${quoted_pkgs}${quoted_pkgs:+, }\"${pkg}\""
    done
    cat > "$(pwd)/opencode-pod.toml" << TOML
[container]
image = "cgr.dev/chainguard/wolfi-base:latest"
packages = [${quoted_pkgs}]
user = "dev"

[mounts]
extra = []

[env]

[network]
forward = []
mode = "bridge"

[security]
http = false
harden = true
TOML
    resolve_project || return 1
    cmd_setup
    container_start
    return $?
  fi

  container_start
}

cmd_setup() {
  if [[ "${1:-}" == "--force-recreate" ]]; then
    resolve_project || return 1
    container_destroy 2>/dev/null || true
    CONTAINER_STATE="nonexistent"
  fi

  resolve_project || return 1

  if ! command -v podman &>/dev/null; then
    classify_error "podman_not_found" 0 ""
    return 1
  fi

  local image="${CONFIG_CONTAINER_IMAGE:-cgr.dev/chainguard/wolfi-base:latest}"
  if ! podman image exists "$image" 2>/dev/null; then
    printf 'Pulling base image: %s\n' "$image"
    if ! podman pull "$image"; then
      classify_error "image_pull" "$?" ""
      return 1
    fi
  fi

  container_setup
}

cmd_stop() {
  resolve_project || return 1
  container_stop
}

cmd_destroy() {
  resolve_project || return 1
  container_destroy
}

cmd_doctor() {
  local fix_mode=false
  if [[ "${1:-}" == "--fix" ]]; then
    # shellcheck disable=SC2034
    fix_mode=true
  fi

  printf '=== opencode-pod doctor ===\n\n'

  printf 'Podman installed: '
  if command -v podman &>/dev/null; then
    local version
    version="$(podman version -f '{{.Version}}' 2>/dev/null || printf 'unknown')"
    printf 'PASS (version %s)\n' "$version"
  else
    printf 'FAIL\n'
    printf '  Fix: Install podman for your distribution.\n'
    detect_distro 2>/dev/null || true
    printf '  Command: %s\n' "${DISTRO_INSTALL_CMD:-See https://podman.io/docs/installation}"
    return 1
  fi

  printf 'Rootless podman: '
  if podman info -f '{{.Host.Security.Rootless}}' 2>/dev/null | grep -q "true"; then
    printf 'PASS\n'
  else
    printf 'FAIL\n'
    printf '  Fix: %s\n' "${DISTRO_SUBUID_INSTRUCTIONS:-Configure subuid/subgid for rootless podman}"
  fi

  printf 'XDG_RUNTIME_DIR: '
  if [[ -n "${XDG_RUNTIME_DIR:-}" ]]; then
    printf 'PASS (%s)\n' "$XDG_RUNTIME_DIR"
  else
    printf 'FAIL\n'
    # shellcheck disable=SC2016
    printf '  Fix: export XDG_RUNTIME_DIR=/run/user/$(id -u)\n'
  fi

  printf 'Wolfi base image: '
  if podman image exists cgr.dev/chainguard/wolfi-base:latest 2>/dev/null; then
    printf 'PASS\n'
  else
    printf 'WARN (not pulled yet — will pull on first start)\n'
  fi

  printf 'Disk space (>2GB): '
  local avail
  avail="$(df -BG "$HOME" 2>/dev/null | awk 'NR==2 {print $4}' | tr -d 'G' || printf '0')"
  if [[ "$avail" -gt 2 ]]; then
    printf 'PASS (%sG available)\n' "$avail"
  else
    printf 'FAIL (%sG available, need 2GB+)\n' "$avail"
    printf '  Fix: Free up disk space or clean old containers.\n'
  fi
}

cmd_upgrade() {
  local pull_image=false
  if [[ "${1:-}" == "--pull" ]]; then
    pull_image=true
  fi

  resolve_project || return 1

  local image="${CONFIG_CONTAINER_IMAGE:-cgr.dev/chainguard/wolfi-base:latest}"
  local image_created
  image_created="$(podman image inspect -f '{{.Created}}' "$image" 2>/dev/null || printf '')"

  if [[ -n "$image_created" ]]; then
    local created_epoch
    created_epoch="$(date -d "$image_created" +%s 2>/dev/null || printf '0')"
    local now_epoch
    now_epoch="$(date +%s)"
    local age_days=$(( (now_epoch - created_epoch) / 86400 ))
    if [[ "$age_days" -ge 30 ]] || $pull_image; then
      printf 'Base image is %s days old. Pulling latest...\n' "$age_days"
      podman pull "$image"
    else
      printf 'Base image is %s days old (OK, < 30 days).\n' "$age_days"
    fi
  fi

  if [[ "$CONTAINER_STATE" != "running" ]]; then
    printf 'Container must be running for package delta check. Run "opencode-pod start" first.\n'
    return 1
  fi

  local toml_packages="${CONFIG_CONTAINER_PACKAGES:-}"
  if [[ -n "$toml_packages" ]]; then
    local installed
    installed="$(podman exec "$CONTAINER_NAME" apk list --installed 2>/dev/null | sed 's/-[0-9].*//' || printf '')"
    # shellcheck disable=SC2086
    for pkg in $toml_packages; do
      if ! printf '%s' "$installed" | grep -qxF "$pkg"; then
        printf 'Installing new package: %s\n' "$pkg"
        podman exec "$CONTAINER_NAME" apk add -U --no-cache "$pkg"
      fi
    done
    # shellcheck disable=SC2086
    for installed_pkg in $installed; do
      if ! printf '%s' " $toml_packages " | grep -q " $installed_pkg "; then
        printf 'Note: %s is installed but not in opencode-pod.toml (not auto-removing).\n' "$installed_pkg"
      fi
    done
  fi

  printf 'Upgrade complete.\n'
}

case "${1:-}" in
  init)     shift; cmd_init "$@" ;;
  start)    shift; cmd_start "$@" ;;
  setup)    shift; cmd_setup "$@" ;;  
  stop)     shift; cmd_stop "$@" ;;
  destroy)  shift; cmd_destroy "$@" ;;
  status)   shift; cmd_status "$@" ;;  
  doctor)   shift; cmd_doctor "$@" ;;
  upgrade)  shift; cmd_upgrade "$@" ;;
  profile)  shift; cmd="${1:-}"; shift 2>/dev/null || true
            case "$cmd" in
              list)    cmd_profile_list "$@" ;;
              info)    cmd_profile_info "$@" ;;
              install) cmd_profile_install "$@" ;;
              update)  cmd_profile_update "$@" ;;
              *)       printf 'Usage: opencode-pod profile <list|info|install|update>\n'; exit 1 ;;
            esac ;;
  --help|-h) usage ;;
  --version|-v) printf 'opencode-pod %s\n' "$SCRIPT_VERSION" ;;
  "")       usage ;;
  *)        printf 'Unknown command: %s\n' "$1"; usage; exit 1 ;;
esac
